<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>@ViewBag.Title</title>
    <link rel="stylesheet" href="~/css/style.css" />
</head>
<body>
    <div class="header">
        <div class="search-div">
            <input type="text" name="searchbox" id="searchbox" placeholder="Search...">
        </div>
        <div class="search-icon-div">
            <a href=""><img src="img/searchicon.png" alt="searchicon"></a>
        </div>
        <div class="navbar">
            <ul>
                <li><a href="login.html">Login</a></li>
                <li><a href="register.html">Register</a></li>
                <li><a href="shop.html">Shop</a></li>
                <li><a href="index.html">Home</a></li>
            </ul>
        </div>
        <div class="dropdown">
            <button class="drop-button"><img src="img/dropdown-icon.png" alt="dropdown-icon"></button>
            <div class="dropdown-content">
                <a href="index.html">Home</a>
                <a href="shop.html">Shop</a>
                <a href="register.html">Register</a>
                <a href="login.html">Login</a>
            </div>
        </div>
    </div>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    <div class="footer">
        <div class="icons">
            <a href="">
                <img src="img/instagramlogo.png" alt="Instagram">
            </a>
        </div>
    </div>
    <script src="script.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
